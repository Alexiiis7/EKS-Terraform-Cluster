variable "AWS_ACCESS_KEY" {
    description = "aws access key"
    type        = string
    default     = "AKIAQNMFRKEYXYRPMRTN"
}

variable "AWS_SECRET_KEY" {
    description = "aws secret key"
    type        = string
    default     = "(insert here aws secret key)"
}

variable "region" {
  description = "AWS region"
  type        = string
  default     = "eu-south-2"
}